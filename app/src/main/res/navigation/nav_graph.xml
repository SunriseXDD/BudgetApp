<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/authFragment">

    <fragment
        android:id="@+id/authFragment"
        android:name="com.Popov.budgetapp.ui.AuthFragment"
        android:label="Авторизация">
        <action
            android:id="@+id/action_authFragment_to_budgetsFragment"
            app:destination="@id/budgetsFragment" />
        <action
            android:id="@+id/action_authFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_authFragment_to_setupNicknameFragment"
            app:destination="@id/setupNicknameFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.Popov.budgetapp.ui.RegisterFragment"
        android:label="Регистрация" />

    <fragment
        android:id="@+id/setupNicknameFragment"
        android:name="com.Popov.budgetapp.ui.SetupNicknameFragment"
        android:label="Никнейм">
        <action
            android:id="@+id/action_setupNicknameFragment_to_budgetsFragment"
            app:destination="@id/budgetsFragment"
            app:launchSingleTop="true"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="false" />
    </fragment>

    <fragment
        android:id="@+id/budgetsFragment"
        android:name="com.Popov.budgetapp.ui.BudgetsFragment"
        android:label="Бюджеты">
        <action
            android:id="@+id/action_budgetsFragment_to_transactionsFragment"
            app:destination="@id/transactionsFragment"
            app:launchSingleTop="true"
            app:restoreState="true" />
    </fragment>

    <fragment
        android:id="@+id/transactionsFragment"
        android:name="com.Popov.budgetapp.ui.TransactionsFragment"
        android:label="Транзакции">
        <action
            android:id="@+id/action_transactionsFragment_to_budgetMembersFragment"
            app:destination="@id/budgetMembersFragment" />
    </fragment>

    <fragment
        android:id="@+id/budgetMembersFragment"
        android:name="com.Popov.budgetapp.ui.BudgetMembersFragment"
        android:label="Участники" />

    <fragment
        android:id="@+id/reportsFragment"
        android:name="com.Popov.budgetapp.ui.ReportsFragment"
        android:label="Отчеты" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.Popov.budgetapp.ui.ProfileFragment"
        android:label="Профиль">
        <action
            android:id="@+id/action_profileFragment_to_transactionsFragment"
            app:destination="@id/transactionsFragment"
            app:launchSingleTop="true"
            app:restoreState="true" />
        <action
            android:id="@+id/action_profileFragment_to_authFragment"
            app:destination="@id/authFragment"
            app:launchSingleTop="true"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <action
        android:id="@+id/action_global_setupNickname"
        app:destination="@id/setupNicknameFragment"
        app:launchSingleTop="true" />
    <action
        android:id="@+id/action_global_budgets"
        app:destination="@id/budgetsFragment"
        app:launchSingleTop="true" />
</navigation>
